# 複製成 .env 後填入實際值
# 資料庫：Supabase → Settings → Database → Connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.supabase.com:5432/postgres"

# Auth.js session 加密金鑰： openssl rand -base64 32
AUTH_SECRET=""

# Vercel Blob（媒體上傳用）
BLOB_READ_WRITE_TOKEN=""
